<style>
  .container {
    position: relative;
    width: 100%;
    min-height: 100vh;
    overflow-x: hidden;
    background: #0a0a0a;
  }

  .content {
    position: relative;
    z-index: 10;
    padding: 6rem 2rem 8rem;
    min-height: 100vh;
  }

  .page-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    color: white;
    text-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    margin-bottom: 3rem;
    text-align: center;
  }

  .footer-text {
    text-align: center;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 600;
    color: rgba(255, 255, 255, 0.8);
    padding: 3rem 2rem;
  }
</style>
